{
  "name": "buddy-reroll",
  "version": "0.3.0",
  "description": "Reroll your Claude Code buddy companion to any species/rarity/eye/hat/shiny combo",
  "type": "module",
  "bin": {
    "buddy-reroll": "index.js"
  },
  "scripts": {
    "help": "bun run index.js --help",
    "list": "bun run index.js --list",
    "verify:runtime": "bun run scripts/verify-runtime.js",
    "verify": "bun run help && bun run list && bun run verify:runtime && npm pack --dry-run"
  },
  "files": [
    "index.js",
    "lib",
    "ui.jsx",
    "sprites.js"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grayashh/buddy-reroll"
  },
  "keywords": [
    "claude",
    "claude-code",
    "buddy",
    "companion",
    "reroll"
  ],
  "dependencies": {
    "chalk": "^5.6.2",
    "ink": "^6.8.0",
    "react": "^19.2.4"
  }
}
